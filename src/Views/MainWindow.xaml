<ui:FluentWindow x:Class="ExModem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExModem"
        xmlns:pages="clr-namespace:ExModem.Views.Pages"
        xmlns:properties="clr-namespace:ExModem.Properties"
        mc:Ignorable="d"
        Title="ExModem" Height="800" Width="1100"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 标题栏 -->
        <ui:TitleBar Title="ExModem" VerticalAlignment="Center" Grid.ColumnSpan="2">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Margin="-3,-16,0,-16" Width="20" Height="20">
                    <ui:ImageIcon.Source>
                        <BitmapImage UriSource="pack://application:,,,/Assets/Icon.png"/>
                    </ui:ImageIcon.Source>
                </ui:ImageIcon>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- 左侧菜单 -->
        <ui:NavigationView x:Name="RootNavigation" Grid.Row="1" OpenPaneLength="180" IsPaneOpen="False" IsBackButtonVisible="Collapsed" Grid.RowSpan="2" Grid.ColumnSpan="2">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem
                    Content="{x:Static properties:Resources.Nav_Network}"
                    NavigationCacheMode="Enabled"
                    TargetPageType="{x:Type pages:StatusPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xE774;" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem
                    Content="{x:Static properties:Resources.Chat}"
                    NavigationCacheMode="Enabled"
                    TargetPageType="{x:Type pages:ChatPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xE715;" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem
                    Content="{x:Static properties:Resources.Nav_Contacts}"
                    NavigationCacheMode="Enabled"
                    TargetPageType="{x:Type pages:ContactsPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xE77B;" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem
                    Content="{x:Static properties:Resources.Settings}"
                    NavigationCacheMode="Disabled"
                    TargetPageType="{x:Type pages:Setting}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xE713;" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>

        <ContentPresenter Grid.Row="1" Grid.RowSpan="2" Grid.ColumnSpan="2" x:Name="ContentPresenterForDialogs"/>
        <ui:SnackbarPresenter Grid.Row="2" Grid.Column="1" VerticalAlignment="Bottom" x:Name="SnackbarPresenter"/>
    </Grid>
</ui:FluentWindow>
