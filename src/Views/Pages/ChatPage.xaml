<Page
    x:Class="ExModem.Views.Pages.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:properties="clr-namespace:ExModem.Properties"
    xmlns:vm="clr-namespace:ExModem.ViewModels"
    xmlns:beh="clr-namespace:ExModem.Behaviors"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:ChatViewModel, IsDesignTimeCreatable=True}"
    Title="ChatPage"
    d:DesignHeight="700"
    d:DesignWidth="1000">

    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="336" MinWidth="300" MaxWidth="400" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===================== 左:会话列表 ===================== -->
        <Border Grid.Column="0" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="24,22,18,12">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:TextBlock FontTypography="Title"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      Text="{x:Static properties:Resources.Chat}" />
                        <TextBlock VerticalAlignment="Bottom" Margin="10,0,0,5" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{Binding SimCapacityText}" />
                    </StackPanel>
                    <ui:Button HorizontalAlignment="Right" VerticalAlignment="Center" Padding="8,3" FontSize="15"
                               Content="＋" ToolTip="{x:Static properties:Resources.Chat_NewConversation}" Command="{Binding NewConversationCommand}" />
                </Grid>

                <ui:TextBox DockPanel.Dock="Top" Margin="24,0,24,10" Height="36" Padding="8,0"
                            VerticalContentAlignment="Center" FontSize="13" PlaceholderText="{x:Static properties:Resources.Chat_SearchPlaceholder}"
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                    <ui:TextBox.Icon>
                        <ui:SymbolIcon Symbol="Search24" />
                    </ui:TextBox.Icon>
                </ui:TextBox>

                <ListView x:Name="ConvList" Margin="14,0,14,0" ItemsSource="{Binding Conversations}"
                          SelectedItem="{Binding SelectedConversation, Mode=TwoWay}"
                          BorderThickness="0" Background="Transparent"
                          StylusSystemGesture="ConvList_StylusSystemGesture"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.PanningMode="VerticalOnly">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="bd" CornerRadius="13" Padding="11,7" Background="Transparent">
                                            <Grid>
                                                <Grid.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="{x:Static properties:Resources.Chat_DeleteConversation}" Click="DeleteConversation_Click" Foreground="#FF4D4F" FontWeight="SemiBold" />
                                                    </ContextMenu>
                                                </Grid.ContextMenu>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0" Width="42" Height="42" Margin="0,0,13,0">
                                                    <Ellipse Fill="{DynamicResource ControlFillColorSecondaryBrush}" />
                                                    <Ellipse x:Name="avBg" Fill="{StaticResource ExGreen}" Visibility="Collapsed" />
                                                    <ui:FontIcon x:Name="avIcon" FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xE77B;"
                                                                 FontSize="18" Foreground="White" Visibility="Collapsed" />
                                                    <Ellipse>
                                                        <Ellipse.Fill>
                                                            <ImageBrush ImageSource="{Binding PhotoPath, Converter={StaticResource PathToImage}}" Stretch="UniformToFill" />
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                </Grid>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock x:Name="PeerText" Text="{Binding DisplayName}" FontSize="16" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                    <TextBlock x:Name="LastText" Text="{Binding LastText}" FontSize="13.5" Margin="0,2,0,0"
                                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="6,0,0,0">
                                                    <TextBlock x:Name="TimeText" HorizontalAlignment="Right" Text="{Binding LastTime}"
                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontSize="11" />
                                                    <Border x:Name="unreadBadge" Margin="0,3,0,0" HorizontalAlignment="Right" MinWidth="18" Height="18"
                                                            CornerRadius="9" Padding="5,0" Background="{StaticResource ExGreen}"
                                                            Visibility="{Binding HasUnread, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock x:Name="unreadText" Text="{Binding Unread}" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                            </Trigger>
                                            <DataTrigger Binding="{Binding PhotoPath}" Value="">
                                                <Setter TargetName="avBg" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="avIcon" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HasUnread}" Value="True">
                                                <Setter TargetName="PeerText" Property="FontWeight" Value="Bold" />
                                            </DataTrigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ExGreen}" />
                                                <Setter TargetName="PeerText" Property="Foreground" Value="White" />
                                                <Setter TargetName="LastText" Property="Foreground" Value="{StaticResource ExCream}" />
                                                <Setter TargetName="TimeText" Property="Foreground" Value="{StaticResource ExCream}" />
                                                <Setter TargetName="avBg" Property="Fill" Value="White" />
                                                <Setter TargetName="avIcon" Property="Foreground" Value="{StaticResource ExGreen}" />
                                                <Setter TargetName="unreadBadge" Property="Background" Value="White" />
                                                <Setter TargetName="unreadText" Property="Foreground" Value="{StaticResource ExGreen}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </DockPanel>
        </Border>

        <GridSplitter Grid.Column="0" Width="5" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                      Background="Transparent" ResizeBehavior="CurrentAndNext" ResizeDirection="Columns" />

        <!-- ===================== 右:气泡线程(DockPanel 钉住发送栏) ===================== -->
        <DockPanel Grid.Column="1" LastChildFill="True">

            <!-- 头部:收件人号码 -->
            <Border DockPanel.Dock="Top" Padding="24,16"
                    BorderThickness="0,0,0,1" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
                <Grid Height="38">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:FontIcon Grid.Column="0" VerticalAlignment="Center" FontFamily="{DynamicResource SegoeFluentIcons}"
                                 Foreground="{DynamicResource TextFillColorSecondaryBrush}" Glyph="&#xE715;" />
                    <Grid Grid.Column="1" Margin="14,0,0,0" Height="30">
                        <!-- 看已有会话:只读显示名字/号码,点击复制 -->
                        <ui:TextBlock VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="18" FontWeight="SemiBold" Cursor="Hand"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      Text="{Binding CurrentTitle}"
                                      ToolTip="{x:Static properties:Resources.Chat_CopyNumberTip}"
                                      MouseLeftButtonUp="HeaderNumber_Click"
                                      Visibility="{Binding IsComposingNew, Converter={StaticResource InvBoolToVis}}" />
                        <!-- 新建:可编辑号码 -->
                        <ui:TextBox VerticalAlignment="Center" Height="30" Padding="10,0" VerticalContentAlignment="Center"
                                    PlaceholderText="{x:Static properties:Resources.Chat_RecipientPlaceholder}"
                                    Text="{Binding CurrentPeer, UpdateSourceTrigger=PropertyChanged}"
                                    Visibility="{Binding IsComposingNew, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                    <Button Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource GreenBtn}" Padding="14,7"
                            Content="{x:Static properties:Resources.Chat_SaveAsContact}" Command="{Binding SaveContactCommand}"
                            Visibility="{Binding CanSaveContact, Converter={StaticResource BoolToVis}}" />
                </Grid>
            </Border>

            <!-- 底部:发送栏(钉死,永远可见) -->
            <Border DockPanel.Dock="Bottom" Padding="12" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderThickness="0,1,0,0" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ui:TextBox Grid.Row="0" Grid.Column="0" x:Name="DraftBox" MaxHeight="120"
                                AcceptsReturn="True" TextWrapping="Wrap"
                                PlaceholderText="{x:Static properties:Resources.Chat_InputPlaceholder}"
                                Text="{Binding Draft, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:Button Grid.Row="0" Grid.Column="1" Margin="8,0,0,0" MinWidth="48"
                               VerticalAlignment="Stretch" Appearance="Transparent" BorderThickness="0" ToolTip="{x:Static properties:Resources.Common_Send}"
                               Command="{Binding SendCommand}">
                        <ui:FontIcon FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xE725;"
                                     FontSize="20" Foreground="#4CA0FF" />
                    </ui:Button>
                </Grid>
            </Border>

            <!-- 中间:消息气泡(填满剩余,可滚动)。正文用轻量 TextBlock,切换/长会话都不卡;瞬间滚到底无动画。 -->
            <ScrollViewer x:Name="MsgScroll" Padding="16,12" VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly">
                <ItemsControl ItemsSource="{Binding SelectedConversation.Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel x:Name="Row" Orientation="Horizontal" Margin="2,5" HorizontalAlignment="Right">
                                <!-- 收到消息左侧头像:命中联系人显示其照片,否则人形图标(与左侧会话列表一致) -->
                                <Grid x:Name="Avatar" Width="30" Height="30" Margin="0,0,8,0" VerticalAlignment="Bottom" Visibility="Collapsed">
                                    <Ellipse Fill="{StaticResource ExGreen}" />
                                    <ui:FontIcon FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xE77B;"
                                                 FontSize="14" Foreground="White" />
                                    <Ellipse>
                                        <Ellipse.Fill>
                                            <ImageBrush Stretch="UniformToFill"
                                                        ImageSource="{Binding DataContext.SelectedConversation.PhotoPath, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource PathToImage}}" />
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </Grid>
                                <Border x:Name="Bubble" CornerRadius="16,16,4,16" Padding="13,9" MaxWidth="440"
                                        BorderThickness="1" BorderBrush="Transparent"
                                        Background="{StaticResource ExGreen}">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{x:Static properties:Resources.Common_Copy}" Click="CopyMessage_Click" />
                                            <MenuItem Header="{x:Static properties:Resources.Common_Delete}" Click="DeleteMessage_Click" Foreground="#FF4D4F" FontWeight="SemiBold" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <StackPanel>
                                        <TextBlock x:Name="BodyText" FontSize="16" TextWrapping="Wrap"
                                                   Foreground="#FFFFFF" beh:OtpText.Source="{Binding Body}" />
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                                            <Border Margin="0,0,6,0" Padding="5,1" CornerRadius="3" VerticalAlignment="Center"
                                                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                                    Visibility="{Binding IsSim, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="SIM" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </Border>
                                            <TextBlock x:Name="TimeLabel" FontSize="12" Opacity="0.8"
                                                       Text="{Binding TimeText}" Foreground="#FFFFFF" />
                                        </StackPanel>
                                        <TextBlock Margin="0,2,0,0" HorizontalAlignment="Right" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#FFD479" Text="{Binding StatusText}"
                                                   Visibility="{Binding ShowStatus, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsIncoming}" Value="True">
                                    <Setter TargetName="Row" Property="HorizontalAlignment" Value="Left" />
                                    <Setter TargetName="Avatar" Property="Visibility" Value="Visible" />
                                    <Setter TargetName="Bubble" Property="CornerRadius" Value="16,16,16,4" />
                                    <Setter TargetName="Bubble" Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
                                    <Setter TargetName="Bubble" Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
                                    <Setter TargetName="BodyText" Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <Setter TargetName="TimeLabel" Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</Page>
