<Page
    x:Class="ExModem.Views.Pages.ContactsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:ExModem.ViewModels"
    xmlns:p="clr-namespace:ExModem.Properties"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:ContactsViewModel, IsDesignTimeCreatable=True}"
    Title="ContactsPage" d:DesignHeight="640" d:DesignWidth="1000">

    <Page.Resources>
        <!-- 列表行(整行模板,选中态整行变绿) -->
        <Style x:Key="ContactRow" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="bd" CornerRadius="13" Padding="11,7" Background="Transparent">
                            <Grid>
                                <Grid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{x:Static p:Resources.Common_Delete}" Click="Delete_Click" Foreground="#FF4D4F" FontWeight="SemiBold" />
                                    </ContextMenu>
                                </Grid.ContextMenu>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Width="42" Height="42" Margin="0,0,13,0">
                                    <Ellipse Fill="{DynamicResource ControlFillColorSecondaryBrush}" />
                                    <Ellipse x:Name="avBg" Fill="{StaticResource ExGreen}" Visibility="Collapsed" />
                                    <ui:FontIcon x:Name="avIcon" FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xE77B;"
                                                 FontSize="18" Foreground="White" Visibility="Collapsed" />
                                    <Ellipse>
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding PhotoPath, Converter={StaticResource PathToImage}}" Stretch="UniformToFill" />
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </Grid>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="nm" Text="{Binding Name}" FontSize="14.5" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <TextBlock x:Name="num" Text="{Binding Number}" FontFamily="{StaticResource MonoFont}"
                                               FontSize="12.5" Margin="0,3,0,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </Trigger>
                            <!-- 无照片才显示绿底+人像;有照片只显示照片(透明角露中性底,不填绿) -->
                            <DataTrigger Binding="{Binding PhotoPath}" Value="">
                                <Setter TargetName="avBg" Property="Visibility" Value="Visible" />
                                <Setter TargetName="avIcon" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSim}" Value="True">
                                <Setter TargetName="avBg" Property="Fill" Value="{StaticResource ExClay}" />
                            </DataTrigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ExGreen}" />
                                <Setter TargetName="nm" Property="Foreground" Value="White" />
                                <Setter TargetName="num" Property="Foreground" Value="{StaticResource ExCream}" />
                                <Setter TargetName="avBg" Property="Fill" Value="White" />
                                <Setter TargetName="avIcon" Property="Foreground" Value="{StaticResource ExGreen}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="336" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===================== 左:列表 ===================== -->
        <Border Grid.Column="0" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="24,22,18,12">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:TextBlock FontTypography="Title"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="{x:Static p:Resources.Contacts_Title}" />
                        <TextBlock VerticalAlignment="Bottom" Margin="10,0,0,5" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{Binding SimCapacityText}" />
                    </StackPanel>
                    <ui:Button HorizontalAlignment="Right" VerticalAlignment="Center" Padding="8,3" FontSize="15"
                               Content="＋" ToolTip="{x:Static p:Resources.Contacts_AddTip}" Command="{Binding NewCommand}" />
                </Grid>

                <ui:TextBox DockPanel.Dock="Top" Margin="24,0,24,10" Height="36" Padding="8,0"
                            VerticalContentAlignment="Center" FontSize="13" PlaceholderText="{x:Static p:Resources.Contacts_SearchPlaceholder}"
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                    <ui:TextBox.Icon>
                        <ui:SymbolIcon Symbol="Search24" />
                    </ui:TextBox.Icon>
                </ui:TextBox>

                <ListView Margin="14,0,14,0" ItemsSource="{Binding ContactsView}"
                          SelectedItem="{Binding SelectedContact, Mode=TwoWay}"
                          ItemContainerStyle="{StaticResource ContactRow}"
                          BorderThickness="0" Background="Transparent"
                          StylusSystemGesture="ContactList_StylusSystemGesture"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.PanningMode="VerticalOnly">
                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="Bold" Margin="10,12,0,4"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListView.GroupStyle>
                </ListView>
            </DockPanel>
        </Border>

        <!-- ===================== 右:详情 / 编辑 ===================== -->
        <Grid Grid.Column="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding EditorActive, Converter={StaticResource InvBoolToVis}}">
                <ui:FontIcon HorizontalAlignment="Center" FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xE77B;"
                             FontSize="44" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                <TextBlock Margin="0,12,0,0" HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{x:Static p:Resources.Contacts_EmptyHint}" />
            </StackPanel>

            <DockPanel Visibility="{Binding EditorActive, Converter={StaticResource BoolToVis}}">
                <Border DockPanel.Dock="Top" Padding="30,18" BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
                    <Grid>
                        <ui:TextBlock VerticalAlignment="Center" FontTypography="Subtitle"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="{Binding EditTitle}" />
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource GreenBtn}"
                                Command="{Binding SaveCommand}" Visibility="{Binding CanSave, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xE73E;" FontSize="13" Margin="0,0,7,0" />
                                <TextBlock Text="{x:Static p:Resources.Common_Save}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="36,30,44,30">
                        <!-- Hero -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                            <Grid Width="104" Height="104">
                                <Border CornerRadius="32" Background="{DynamicResource ControlFillColorSecondaryBrush}" />
                                <Border CornerRadius="32" Background="{StaticResource ExGreen}"
                                        Visibility="{Binding HasEditPhoto, Converter={StaticResource InvBoolToVis}}" />
                                <ui:FontIcon FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xE77B;" FontSize="46" Foreground="White"
                                             Visibility="{Binding HasEditPhoto, Converter={StaticResource InvBoolToVis}}" />
                                <Border CornerRadius="32">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding EditPhotoPath, Converter={StaticResource PathToImage}, ConverterParameter=384}" Stretch="UniformToFill" />
                                    </Border.Background>
                                </Border>
                                <Border Width="36" Height="36" CornerRadius="18" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        Background="{StaticResource ExClay}" BorderThickness="4" Cursor="Hand"
                                        BorderBrush="{DynamicResource ApplicationBackgroundBrush}"
                                        Visibility="{Binding CanPickPhoto, Converter={StaticResource BoolToVis}}">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding PickPhotoCommand}" />
                                    </Border.InputBindings>
                                    <ui:FontIcon FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xE722;" FontSize="14" Foreground="White" />
                                </Border>
                            </Grid>
                            <StackPanel Margin="22,0,0,0" VerticalAlignment="Center">
                                <ui:TextBlock FontTypography="Title" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="{Binding EditName}" />
                                <Border Margin="0,8,0,0" HorizontalAlignment="Left" Padding="10,4" CornerRadius="5"
                                        Background="{StaticResource ExGreen}"
                                        Visibility="{Binding ShowHomeChip, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{x:Static p:Resources.Common_Phone}" FontSize="11" FontWeight="SemiBold" Foreground="White" />
                                </Border>
                                <Border Margin="0,8,0,0" HorizontalAlignment="Left" Padding="10,4" CornerRadius="5"
                                        Background="{StaticResource ExClay}"
                                        Visibility="{Binding EditingSim, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{x:Static p:Resources.Common_SimCard}" FontSize="11" FontWeight="SemiBold" Foreground="White" />
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <!-- 表单(输入框拉满) -->
                        <TextBlock Margin="2,0,0,9" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{x:Static p:Resources.Contacts_Name}" />
                        <ui:TextBox HorizontalAlignment="Stretch" FontSize="15" Padding="14,10" KeyDown="Field_KeyDown"
                                    Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="2,22,0,9" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{x:Static p:Resources.Contacts_PhoneNumber}" />
                        <ui:TextBox HorizontalAlignment="Stretch" FontSize="15" Padding="14,10" FontFamily="{StaticResource MonoFont}"
                                    KeyDown="Field_KeyDown" Text="{Binding EditNumber, UpdateSourceTrigger=PropertyChanged}" />

                        <!-- 保存到:下拉选择(仅新建) -->
                        <StackPanel Margin="0,22,0,0" Visibility="{Binding IsNew, Converter={StaticResource BoolToVis}}">
                            <TextBlock Margin="2,0,0,9" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{x:Static p:Resources.Contacts_SaveTo}" />
                            <ComboBox HorizontalAlignment="Left" MinWidth="200" SelectedIndex="{Binding SaveTargetIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="{x:Static p:Resources.Common_Phone}" />
                                <ComboBoxItem Content="{x:Static p:Resources.Common_SimCard}" />
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </Grid>
</Page>
